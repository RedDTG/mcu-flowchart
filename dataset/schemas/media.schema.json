{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Marvel Media",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "release date",
    "phase",
    "summary",
    "mediatype",
    "poster",
    "connections"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "release date": {
      "type": "string",
      "format": "date"
    },
    "phase": {
      "type": "integer",
      "minimum": 1
    },
    "mediatype": {
      "type": "string",
      "enum": ["movie", "show", "special"]
    },
    "poster": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "connections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "optionnal",
        "references"
      ],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connection"
          }
        },
        "optionnal": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connection"
          }
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connection"
          }
        }
      }
    }
  },
  "$defs": {
    "connection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "media_id"
      ],
      "properties": {
        "media_id": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        },
        "importance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
